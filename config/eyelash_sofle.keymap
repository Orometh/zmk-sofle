#define ZMK_POINTING_DEFAULT_MOVE_VAL 1200  // 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 25   // 10

#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <behaviors/runtime-sensor-rotate.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>
#include "keys_es_latin_american.h"

&mmv_input_listener { input-processors = <&zip_xy_scaler 2 1>; };

&msc_input_listener { input-processors = <&zip_scroll_scaler 2 1>; };

&msc {
    acceleration-exponent = <1>;      // 0
    time-to-max-speed-ms = <100>;       // 300
    delay-ms = <0>;                   // 0
};

&mmv {
    time-to-max-speed-ms = <500>;
    acceleration-exponent = <1>;
    trigger-period-ms = <16>;
};

&soft_off { hold-time-ms = <2000>; };

/ {
    // Encoder: scroll vertical (capa Base)
    scroll_encoder: scroll_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;
        tap-ms = <100>;
    };

    // Encoder: scroll horizontal (capa LOWER)
    scroll_h: scroll_h {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_RIGHT>, <&msc SCRL_LEFT>;
        tap-ms = <100>;
    };

    behaviors {
        // Encoder: volumen (capa RAISE)
        rsr_vol: rsr_vol {
            compatible = "zmk,behavior-runtime-sensor-rotate";
            #sensor-binding-cells = <0>;
            tap-ms = <5>;
            cw-binding = <&kp C_VOL_UP>;
            ccw-binding = <&kp C_VOL_DN>;
        };

        // Encoder: brillo RGB (capa AJUSTE)
        rsr_rgb: rsr_rgb {
            compatible = "zmk,behavior-runtime-sensor-rotate";
            #sensor-binding-cells = <0>;
            tap-ms = <5>;
            cw-binding = <&rgb_ug RGB_BRI>;
            ccw-binding = <&rgb_ug RGB_BRD>;
        };

        rsr_trans: rsr_trans {
            compatible = "zmk,behavior-runtime-sensor-rotate";
            #sensor-binding-cells = <0>;
            tap-ms = <0>;
        };
    };

    // Tecla "¿": tap=¿ · Shift=¡ · AltGr=? (envia Shift+MINUS = ? en Latam)
    qmark: qmark {
        compatible = "zmk,behavior-mod-morph";
        #binding-cells = <0>;
        bindings = <&kp EQUAL>, <&kp LS(MINUS)>;
        mods = <(MOD_RALT)>;
    };

    // AJUSTE = LOWER + RAISE mantenidas juntas
    conditional_layers {
        compatible = "zmk,conditional-layers";
        tri_layer {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };

    combos {
        compatible = "zmk,combos";

        softoff {
            bindings = <&soft_off>;
            key-positions = <14 28 40>;
        };
    };

    macros {
        SHIFT_MCLK: SHIFT_MCLK {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_SHIFT>,
                <&macro_press>,
                <&mkp MB3>,
                <&macro_pause_for_release>,
                <&macro_release>,
                <&kp LEFT_SHIFT &mkp MB3>;

            label = "SHIFT_MCLK";
        };

        // Tecla muerta + espacio = backtick literal (en Latam ` es muerta)
        grave_lit: grave_lit {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp ES_GRAVE>, <&kp SPACE>;
            label = "GRAVE_LIT";
        };

        // Tecla muerta + espacio = ~ literal (en Latam ~ es muerta)
        tilde_lit: tilde_lit {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp ES_TILDE>, <&kp SPACE>;
            label = "TILDE_LIT";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ===== BASE =====
        // Columna central = joystick (mueve el mouse). Pulgar central = click izq. Encoder press = click der.
        layer0 {
            bindings = <
&kp ESC     &kp N1     &kp N2     &kp N3     &kp N4    &kp N5      &mmv MOVE_UP     &kp N6   &kp N7     &kp N8     &kp N9    &kp N0     &qmark
&kp TAB     &kp Q      &kp W      &kp E      &kp R     &kp T       &mmv MOVE_DOWN   &kp Y    &kp U      &kp I      &kp O     &kp P      &kp ES_ACUTE
&kp ES_RBRC &kp A      &kp S      &kp D      &kp F     &kp G       &mmv MOVE_LEFT   &kp H    &kp J      &kp K      &kp L     &kp ES_N_TILDE  &kp ES_LBRC
&kp LSHFT   &kp Z      &kp X      &kp C      &kp V     &kp B       &mmv MOVE_RIGHT  &kp N    &kp M      &kp COMMA  &kp DOT   &kp ES_MINUS    &kp BSPC
&mkp RCLK   &kp C_PP   &kp LCTRL  &mo 1      &kp LALT  &kp LGUI    &mkp LCLK        &kp RET  &kp SPACE  &mo 2      &kp RALT  &kp K_APP
            >;
            sensor-bindings = <&scroll_encoder &rsr_trans>;
            display-name = "Base";
        };

        // ===== LOWER =====  encoder: scroll lateral + click medio
        layer_1 {
            bindings = <
&kp GRAVE       &kp F1           &kp F2          &kp F3           &kp F4           &kp F5             &mmv MOVE_UP     &kp F6           &kp F7           &kp F8      &kp F9     &kp F10           &kp LG(LS(S))
&kp MINUS       &kp GRAVE        &mkp LCLK       &mkp MCLK        &mkp RCLK        &mkp MB4           &mmv MOVE_DOWN   &kp PG_UP        &kp END          &kp UP      &kp HOME   &kp MINUS         &kp EQUAL
&kp NON_US_BSLH &kp TILDE        &rgb_ug RGB_HUI &rgb_ug RGB_HUD  &trans           &mkp MB5           &mmv MOVE_LEFT   &kp PG_DN        &kp LEFT         &kp DOWN    &kp RIGHT  &kp LEFT_BRACKET  &kp RIGHT_BRACKET
&trans      &rgb_ug RGB_OFF  &rgb_ug RGB_ON  &rgb_ug RGB_EFF  &rgb_ug RGB_EFR  &rgb_ug RGB_SPI    &mmv MOVE_RIGHT  &rgb_ug RGB_BRI  &rgb_ug RGB_BRD  &kp INSERT  &kp F11    &kp F12           &trans
&mkp MCLK   &trans           &trans          &trans           &trans           &trans             &mkp LCLK        &trans           &trans           &trans      &trans     &trans
            >;
            sensor-bindings = <&scroll_h &rsr_trans>;
            display-name = "Lower";
        };

        // ===== RAISE =====  encoder: volumen + mute
        layer_2 {
            bindings = <
&kp ES_LPAR   &kp ES_RPAR  &kp ES_LBRC  &kp ES_RBRC  &kp ES_LBKT  &kp ES_RBKT    &mmv MOVE_UP     &kp F6  &kp F7  &kp F8      &kp F9     &kp F10      &trans
&kp ES_EQUAL  &kp ES_PLUS  &kp ES_MINUS &kp ES_STAR  &kp ES_FSLH  &kp ES_BSLH    &mmv MOVE_DOWN   &trans  &trans  &kp F11     &kp F12    &trans       &trans
&kp ES_LT     &kp ES_GT    &kp ES_PIPE  &grave_lit   &tilde_lit   &kp ES_UNDER   &mmv MOVE_LEFT   &trans  &trans  &trans      &trans     &trans       &trans
&trans        &trans       &trans       &trans       &trans       &trans         &mmv MOVE_RIGHT  &trans  &trans  &sys_reset  &soft_off  &bootloader  &kp DEL
&kp C_MUTE    &trans       &trans       &trans       &trans       &trans         &mkp LCLK        &trans  &trans  &trans      &trans     &trans
            >;
            sensor-bindings = <&rsr_vol &rsr_trans>;
            display-name = "Raise";
        };

        // ===== AJUSTE =====  Bluetooth / output / reset · encoder: brillo RGB
        layer_3 {
            bindings = <
&bt BT_SEL 0  &bt BT_SEL 1   &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&bt BT_CLR    &bt BT_CLR_ALL &trans        &trans        &trans        &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&out OUT_USB  &out OUT_BLE   &trans        &trans        &trans        &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&sys_reset    &bootloader    &trans        &trans        &trans        &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans        &trans         &trans        &trans        &trans        &trans    &trans  &trans  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&rsr_rgb &rsr_trans>;
            display-name = "Adjust";
        };

        layer_4 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
            >;
            sensor-bindings = <&rsr_vol &rsr_trans>;
            display-name = "LAYER4";
        };
    };
};
